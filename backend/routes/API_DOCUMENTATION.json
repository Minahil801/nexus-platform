              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Q1 Investment Discussion\",\n  \"description\": \"Discussing investment opportunities\",\n  \"participants\": [\"USER_ID_HERE\"],\n  \"startTime\": \"2026-03-20T10:00:00Z\",\n  \"endTime\": \"2026-03-20T11:00:00Z\",\n  \"meetingLink\": \"https://meet.example.com/abc123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/meetings/create",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "meetings", "create"]
            }
          }
        },
